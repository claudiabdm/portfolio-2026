<style lang="scss">
  .stroke {
    stroke-width: 0.5;
    stroke-opacity: 1;
    stroke: var(--stroke);
    color: var(--stroke);
  }

  .page {
    fill: var(--white);
  }

  .cls-2 {
    fill: var(--gray);
  }

  .cls-4 {
    fill: var(--white);
  }

  .cls-8 {
    fill: var(--stroke);
  }

  .gear {
    &__top {
      transform-box: fill-box;
      transform-origin: center;
      fill: var(--gray);
      animation: rotate 5s infinite linear;
    }

    &__code {
      stroke: var(--gray);
      stroke-width: 1.5;
      fill: var(--stroke);
    }
  }

  .cls-10 {
    fill: var(--primary);
  }

  .button {
    fill: var(--tertiary);
  }

  .bottom-line {
    fill: var(--stroke);
  }

  .building {
    fill: var(--secondary);
    animation-name: stretch;
    animation-duration: 0.75s;
    animation-iteration-count: infinite;
    animation-direction: alternate;
    animation-timing-function: linear;

    &--side {
      animation-delay: 0.75s;
      fill: var(--tertiary);
    }
  }

  .building-windows {
    fill: var(--blue);
  }

  .building-top {
    fill: var(--blue);
  }

  @keyframes rotate {
    from {
      transform: rotate(0);
    }

    to {
      transform: rotate(359deg);
    }
  }

  @keyframes stretch {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(0, 5px, 0);
    }
  }
</style>
