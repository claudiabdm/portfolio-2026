---
interface Props {
  level: `h${1 | 2 | 3 | 4 | 5 | 6}`;
  class?: string;
}

const { class: className, level } = Astro.props;
const HeadingTag = level;
---

<HeadingTag class:list={["title", "title-deco", className]}><slot /></HeadingTag>

<style lang="scss">
  .title {
    display: block;
    font-family: var(--font-family-secondary);
    font-weight: 600;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  @keyframes caret-blink {
    from,
    to {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
